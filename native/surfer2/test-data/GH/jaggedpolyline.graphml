<?xml version="1.0"?>
<graphml xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://graphml.graphdrawing.org/xmlns">
  <key attr.name="vertex-coordinate-x" attr.type="string" for="node" id="x">
    <default>0</default>
  </key>
  <key attr.name="vertex-coordinate-y" attr.type="string" for="node" id="y">
    <default>0</default>
  </key>
  <key attr.name="edge-weight" attr.type="string" for="edge" id="w">
    <default>1</default>
  </key>
  <key attr.name="edge-weight-additive" attr.type="string" for="edge" id="wa">
    <default>0</default>
  </key>
  <graph edgedefault="undirected">
    <node id="0">
      <data key="x">0</data>
      <data key="y">0</data>
    </node>
    <node id="1">
      <data key="x">7.5094699856290994</data>
      <data key="y">0</data>
    </node>
    <node id="2">
      <data key="x">0.22321142207815292</data>
      <data key="y">5.41553426422934</data>
    </node>
    <node id="3">
      <data key="x">7.233112986865688</data>
      <data key="y">5.6121728979648511</data>
    </node>
    <node id="4">
      <data key="x">-0.46236651716185406</data>
      <data key="y">14.588460800107502</data>
    </node>
    <node id="5">
      <data key="x">7.0471034684672595</data>
      <data key="y">26.269858555530554</data>
    </node>
    <edge source="0" target="1">
      <data key="w">1</data>
    </edge>
    <edge source="1" target="2">
      <data key="w">1</data>
    </edge>
    <edge source="2" target="3">
      <data key="w">1</data>
    </edge>
    <edge source="3" target="4">
      <data key="w">1</data>
    </edge>
    <edge source="4" target="5">
      <data key="w">1</data>
    </edge>
  </graph>
</graphml>