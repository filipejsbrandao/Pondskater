<?xml version="1.0" encoding="Windows-1252"?>
<xs:schema xmlns="http://tempuri.org/ipe" elementFormDefault="qualified" targetNamespace="http://tempuri.org/ipe" xmlns:xs="http://www.w3.org/2001/XMLSchema">
