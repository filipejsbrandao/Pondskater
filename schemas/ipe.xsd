              </xs:restriction>
            </xs:simpleType>
          </xs:attribute>
          <xs:attribute name="stroke" type="xs:string" />
          <xs:attribute name="fill" type="xs:string" />
          <xs:attribute default="normal" name="tiling" type="xs:string" />
          <xs:attribute default="normal" name="gradient" type="xs:string" />
          <xs:attribute name="dash" type="xs:string" />
          <xs:attribute default="normal" name="pen" type="xs:string" />
          <xs:attribute default="normal" name="opacity" type="xs:string" />
          <xs:attribute name="cap" type="xs:string" />
          <xs:attribute name="join" type="xs:string" />
