          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="name" type="xs:string" use="required" />
      <xs:attribute name="size" type="xs:string" />
      <xs:attribute name="pos" type="xs:string" />
      <xs:attribute default="black" name="stroke" type="xs:string" />
      <xs:attribute default="black" name="fill" type="xs:string" />
      <xs:attribute default="normal" name="pen" type="xs:string" />
    </xs:complexType>
  </xs:element>
  <xs:element name="text">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:string">
          <xs:attribute name="layer" type="xs:string" />
