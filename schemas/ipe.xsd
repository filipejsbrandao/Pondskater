                <xs:enumeration value="DeviceCMYK" />
              </xs:restriction>
            </xs:simpleType>
          </xs:attribute>
          <xs:attribute fixed="8" name="BitsPerComponent" type="xs:string" />
          <xs:attribute name="ColorKey" type="xs:string" />
          <xs:attribute name="length" type="xs:string" />
          <xs:attribute name="encoding">
            <xs:simpleType>
              <xs:restriction base="xs:NMTOKEN">
                <xs:enumeration value="base64" />
              </xs:restriction>
            </xs:simpleType>
          </xs:attribute>
          <xs:attribute name="Filter">
            <xs:simpleType>
              <xs:restriction base="xs:NMTOKEN">
                <xs:enumeration value="FlateDecode" />
                <xs:enumeration value="DCTDecode" />
              </xs:restriction>
            </xs:simpleType>
          </xs:attribute>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="page">
    <xs:complexType>
      <xs:sequence>
        <xs:element minOccurs="0" maxOccurs="1" ref="notes" />
        <xs:element minOccurs="0" maxOccurs="unbounded" ref="layer" />
        <xs:element minOccurs="0" maxOccurs="unbounded" ref="view" />
        <xs:choice minOccurs="0" maxOccurs="unbounded">
          <xs:element ref="group" />
          <xs:element ref="image" />
          <xs:element ref="use" />
          <xs:element ref="text" />
          <xs:element ref="path" />
        </xs:choice>
      </xs:sequence>
      <xs:attribute name="title" type="xs:string" />
      <xs:attribute name="section" type="xs:string" />
      <xs:attribute name="subsection" type="xs:string" />
      <xs:attribute default="yes" name="marked">
        <xs:simpleType>
          <xs:restriction base="xs:NMTOKEN">
            <xs:enumeration value="yes" />
            <xs:enumeration value="no" />
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="notes" type="xs:string" />
  <xs:element name="layer">
    <xs:complexType>
      <xs:attribute name="name" type="xs:string" use="required" />
      <xs:attribute default="yes" name="edit">
        <xs:simpleType>
          <xs:restriction base="xs:NMTOKEN">
            <xs:enumeration value="yes" />
            <xs:enumeration value="no" />
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute default="visible" name="snap">
        <xs:simpleType>
          <xs:restriction base="xs:NMTOKEN">
            <xs:enumeration value="never" />
