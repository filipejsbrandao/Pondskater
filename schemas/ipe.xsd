          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="data" type="xs:string" />
    </xs:complexType>
  </xs:element>
  <xs:element name="view">
    <xs:complexType>
      <xs:choice minOccurs="0" maxOccurs="unbounded">
        <xs:element ref="map" />
