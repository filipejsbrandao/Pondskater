        <xs:choice minOccurs="0" maxOccurs="unbounded">
          <xs:element ref="bitmap" />
          <xs:element ref="ipestyle" />
        </xs:choice>
        <xs:element minOccurs="1" maxOccurs="unbounded" ref="page" />
      </xs:sequence>
      <xs:attribute name="creator" type="xs:string" />
      <xs:attribute name="version" type="xs:string" use="required" />
    </xs:complexType>
  </xs:element>
  <xs:element name="info">
    <xs:complexType>
      <xs:attribute name="created" type="xs:string" />
      <xs:attribute name="modified" type="xs:string" />
      <xs:attribute name="title" type="xs:string" />
      <xs:attribute name="author" type="xs:string" />
      <xs:attribute name="subject" type="xs:string" />
      <xs:attribute name="keywords" type="xs:string" />
      <xs:attribute fixed="fullscreen" name="pagemode" type="xs:string" />
      <xs:attribute name="numberpages">
        <xs:simpleType>
          <xs:restriction base="xs:NMTOKEN">
            <xs:enumeration value="yes" />
            <xs:enumeration value="no" />
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute default="pdftex" name="tex">
        <xs:simpleType>
          <xs:restriction base="xs:NMTOKEN">
            <xs:enumeration value="pdftex" />
            <xs:enumeration value="xetex" />
            <xs:enumeration value="luatex" />
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="preamble" type="xs:string" />
  <xs:element name="bitmap">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:string">
          <xs:attribute name="id" type="xs:string" use="required" />
          <xs:attribute name="width" type="xs:string" use="required" />
          <xs:attribute name="height" type="xs:string" use="required" />
          <xs:attribute default="DeviceRGB" name="ColorSpace">
            <xs:simpleType>
              <xs:restriction base="xs:NMTOKEN">
                <xs:enumeration value="DeviceGray" />
