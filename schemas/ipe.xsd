    </xs:complexType>
  </xs:element>
  <xs:element name="group">
    <xs:complexType>
      <xs:sequence>
        <xs:choice minOccurs="0" maxOccurs="unbounded">
          <xs:element ref="group" />
          <xs:element ref="image" />
          <xs:element ref="use" />
          <xs:element ref="text" />
          <xs:element ref="path" />
        </xs:choice>
      </xs:sequence>
      <xs:attribute name="layer" type="xs:string" />
      <xs:attribute default="1 0 0 1 0 0" name="matrix" type="xs:string" />
      <xs:attribute name="pin">
        <xs:simpleType>
          <xs:restriction base="xs:NMTOKEN">
            <xs:enumeration value="yes" />
            <xs:enumeration value="h" />
            <xs:enumeration value="v" />
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute default="affine" name="transformations">
        <xs:simpleType>
          <xs:restriction base="xs:NMTOKEN">
            <xs:enumeration value="affine" />
            <xs:enumeration value="rigid" />
            <xs:enumeration value="translations" />
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="clip" type="xs:string" />
      <xs:attribute name="url" type="xs:string" />
      <xs:attribute name="decoration" type="xs:string" />
    </xs:complexType>
  </xs:element>
  <xs:element name="image">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:string">
          <xs:attribute name="layer" type="xs:string" />
          <xs:attribute default="1 0 0 1 0 0" name="matrix" type="xs:string" />
          <xs:attribute name="pin">
            <xs:simpleType>
              <xs:restriction base="xs:NMTOKEN">
                <xs:enumeration value="yes" />
                <xs:enumeration value="h" />
                <xs:enumeration value="v" />
              </xs:restriction>
            </xs:simpleType>
          </xs:attribute>
          <xs:attribute default="affine" name="transformations">
            <xs:simpleType>
              <xs:restriction base="xs:NMTOKEN">
                <xs:enumeration value="affine" />
                <xs:enumeration value="rigid" />
                <xs:enumeration value="translations" />
              </xs:restriction>
            </xs:simpleType>
          </xs:attribute>
          <xs:attribute name="rect" type="xs:string" use="required" />
          <xs:attribute name="bitmap" type="xs:string" />
          <xs:attribute name="width" type="xs:string" />
          <xs:attribute name="height" type="xs:string" />
          <xs:attribute default="DeviceRGB" name="ColorSpace">
            <xs:simpleType>
              <xs:restriction base="xs:NMTOKEN">
                <xs:enumeration value="DeviceGray" />
