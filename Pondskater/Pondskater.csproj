<Project Sdk="Microsoft.NET.Sdk">
	
  <PropertyGroup>
    <TargetFrameworks>net7.0;net48</TargetFrameworks>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <LangVersion>8.0</LangVersion>
    <Version>0.0.2</Version>
    <AssemblyName>Pondskater</AssemblyName>
    <Title>Pondskater</Title>
    <Description>Pondskater provides tools for offseting, obtaining the straight skeleton and creating roofs or topographic features. It is a wrap around the library Surfer2 developed by the University of Salzburg's Computational Geometry and Applications Lab. Surfer2 is an implementation of Aichholzer and Aurenhammer's triangulation based straight skeleton algorithm using CGAL. </Description>
    <TargetExt>.gha</TargetExt>
    <NoWarn>NU1701;NETSDK1086</NoWarn>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <BaseOutputPath>bin/Pondskater/</BaseOutputPath>
  </PropertyGroup>

  <PropertyGroup Condition="'$(TargetFramework)'=='net7.0'">
    <Nullable>enable</Nullable>
    <NoWarn>$(NoWarn);CS8600;CS8601;CS8602;CS8603;CS8604;CS8618;CS8625;CS8632;CA1416</NoWarn>
  </PropertyGroup>

  <PropertyGroup Condition="'$(TargetFramework)'=='net48'">
    <Nullable>disable</Nullable>
  </PropertyGroup>
  
  <ItemGroup>
    <PackageReference Include="Grasshopper" Version="8.0.23164.14305-wip" IncludeAssets="compile;build" />
    <PackageReference Include="System.Drawing.Common" Version="7.0.0" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources/roofer.png" />
    <EmbeddedResource Include="Resources/offset.png" />
    <EmbeddedResource Include="Resources/skeleton2d.png" />
    <EmbeddedResource Include="Resources/ReadGML.png" />
    <EmbeddedResource Include="Resources/WriteGML.png" />
    <EmbeddedResource Include="Resources/RandomHamilton.png" />
    <EmbeddedResource Include="Resources/3dcp.png" />
    <EmbeddedResource Include="Resources/EdgeAligned.png" />
    <EmbeddedResource Include="Resources/Eulerian.png" />
    <EmbeddedResource Include="Resources/Hamiltonian.png" />
    <EmbeddedResource Include="Resources/L_Component.png" />
    <EmbeddedResource Include="Resources/MBR.png" />
    <EmbeddedResource Include="Resources/Metric.png" />
    <EmbeddedResource Include="Resources/Mitter_Component.png" />
    <EmbeddedResource Include="Resources/N_Component.png" />
    <EmbeddedResource Include="Resources/PolygonWidth.png" />
    <EmbeddedResource Include="Resources/Pondskater_Icon.png" />
    <EmbeddedResource Include="Resources/Symmetrical.png" />
    <EmbeddedResource Include="Resources/T_Component.png" />
  </ItemGroup>

  <!-- Copy built plugin artifact to Pondskater_GH/dist after build -->
  <Target Name="CopyGhaToDist" AfterTargets="Build">
    <PropertyGroup>
      <_DistDir>$(MSBuildThisFileDirectory)..\Pondskater_GH\dist\</_DistDir>
    </PropertyGroup>
    <MakeDir Directories="$(_DistDir)" />
    <ItemGroup>
      <_BuiltGhaFiles Include="$(OutputPath)*$(TargetExt)" />
    </ItemGroup>
    <Copy SourceFiles="@(_BuiltGhaFiles)" DestinationFolder="$(_DistDir)" SkipUnchangedFiles="true" />
  </Target>

</Project>
