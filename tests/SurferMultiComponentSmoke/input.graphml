<?xml version="1.0" encoding="utf-8"?><graphml xmlns="http://graphml.graphdrawing.org/xmlns"><key id="x" for="node" attr.name="vertex-coordinate-x" attr.type="string" /><key id="y" for="node" attr.name="vertex-coordinate-y" attr.type="string" /><key id="w" for="edge" attr.name="edge-weight" attr.type="string"><default>1</default></key><key id="wa" for="edge" attr.name="edge-weight-additive" attr.type="string"><default>0</default></key><graph edgedefault="undirected"><node id="0"><data key="x">0</data><data key="y">0</data></node><node id="1"><data key="x">10</data><data key="y">0</data></node><node id="2"><data key="x">10</data><data key="y">10</data></node><node id="3"><data key="x">0</data><data key="y">10</data></node><node id="4"><data key="x">20</data><data key="y">0</data></node><node id="5"><data key="x">30</data><data key="y">0</data></node><node id="6"><data key="x">30</data><data key="y">10</data></node><node id="7"><data key="x">20</data><data key="y">10</data></node><edge source="0" target="1"><data key="w">1</data></edge><edge source="1" target="2"><data key="w">1</data></edge><edge source="2" target="3"><data key="w">1</data></edge><edge source="3" target="0"><data key="w">1</data></edge><edge source="4" target="5"><data key="w">1</data></edge><edge source="5" target="6"><data key="w">1</data></edge><edge source="6" target="7"><data key="w">1</data></edge><edge source="7" target="4"><data key="w">1</data></edge></graph></graphml>